# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=True

# Database
DATABASE_URL=sqlite:///afharchive.db

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# JoshAtticusID OAuth
JOSHATTICUS_CLIENT_ID=your-joshatticus-client-id
JOSHATTICUS_CLIENT_SECRET=your-joshatticus-client-secret

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_CONTENT_LENGTH=5368709120
ALLOWED_EXTENSIONS=zip,apk,img,tar,gz,xz,7z,rar,md5,tgz

# Email Configuration (Resend or SMTP)
EMAIL_PROVIDER=resend  # or 'smtp'
RESEND_API_KEY=your-resend-api-key

# SMTP Configuration (only used if EMAIL_PROVIDER=smtp)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=AFHArchive <afh@emails.joshattic.us>

# Rate Limiting
DOWNLOAD_SPEED_LIMIT=10485760

# Resend Configuration
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=your-email@example.com

# AI Autoreviewer (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key
